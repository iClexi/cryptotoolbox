# Frontend/API
APP_ENV="production"
APP_URL="https://cryptotoolbox.iclexi.tech"
APP_ORIGIN="https://cryptotoolbox.iclexi.tech"
ALLOWED_ORIGINS="https://cryptotoolbox.iclexi.tech"
PORT="3000"

# Security
# Use a long random value in production.
SESSION_SECRET="change-me-to-a-long-random-secret"
FORCE_HTTPS="true"
COOKIE_SECURE="true"

# PostgreSQL
DB_HOST="localhost"
DB_PORT="5432"
DB_NAME="cryptotoolbox"
DB_USER="postgres"
DB_PASSWORD="change-me"
DB_SSL="false"
# DATABASE_URL can be used instead of the DB_* values:
# DATABASE_URL="postgres://postgres:postgres@localhost:5432/cryptotoolbox"

# Optional initial admin. Set ADMIN_PIN locally before you need admin actions.
ADMIN_USERNAME="iclexi_admin"
ADMIN_EMAIL="admin@cryptotoolbox.iclexi.tech"
# 6 to 8 digits. 4-digit PINs are only accepted for legacy logins.
ADMIN_PIN=""

# Password reset email. Leave SMTP_HOST empty until the mail server is ready.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_REQUIRE_TLS="true"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="CryptoToolbox <no-reply@cryptotoolbox.iclexi.tech>"
RESET_TOKEN_TTL_MINUTES="30"
AUTH_RATE_LIMIT="20"
PASSWORD_RESET_RATE_LIMIT="5"
ACCOUNT_LOCK_ATTEMPTS="5"
ACCOUNT_LOCK_MINUTES="15"

# Gemini AI
GEMINI_API_KEY="MY_GEMINI_API_KEY"
