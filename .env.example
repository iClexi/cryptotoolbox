# Frontend/API
APP_URL="http://localhost:3000"
APP_ORIGIN="http://localhost:3000"
ALLOWED_ORIGINS="http://localhost:3000"
PORT="3000"

# Security
# Use a long random value in production.
SESSION_SECRET="change-me-to-a-long-random-secret"
FORCE_HTTPS="false"
COOKIE_SECURE="false"

# PostgreSQL
DB_HOST="localhost"
DB_PORT="5432"
DB_NAME="cryptotoolbox"
DB_USER="postgres"
DB_PASSWORD="postgres"
DB_SSL="false"
# DATABASE_URL can be used instead of the DB_* values:
# DATABASE_URL="postgres://postgres:postgres@localhost:5432/cryptotoolbox"

# Optional initial admin. Set ADMIN_PIN locally before you need admin actions.
ADMIN_USERNAME="admin"
ADMIN_EMAIL="admin@example.com"
ADMIN_PIN=""

# Gemini AI
GEMINI_API_KEY="MY_GEMINI_API_KEY"
